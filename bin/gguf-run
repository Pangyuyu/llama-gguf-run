#!/usr/bin/env node

const { program } = require('commander');
const chalk = require('chalk');
const inquirer = require('inquirer');
const path = require('path');
const { scanGGUFFiles } = require('../src/scanner');
const { buildPromptQuestions } = require('../src/prompts');
const { buildLlamaCommand } = require('../src/builder');
const { runLlama } = require('../src/runner');

// CLI 参数定义
program
  .name('gguf-run')
  .description('Interactive CLI tool to run GGUF models with llama')
  .option('-m, --model <file>', 'GGUF model file')
  .option('-j, --mmproj <file>', 'Multimodal projection file (.gguf)')
  .option('-c, --ctx-size <size>', 'Context size', '2048')
  .option('-H, --host <host>', 'Server host', '127.0.0.1')
  .option('-p, --port <port>', 'Server port', '8080')
  .option('-l, --llama-command <command>', 'Llama command name', 'llama-server')
  .option('-e, --extra-args <args>', 'Additional llama arguments (e.g., "--n-gpu-layers 35 --threads 4")')
  .version('1.0.0')
  .action(async (options) => {
    try {
      await runInteractive(options);
    } catch (error) {
      console.error(chalk.red(`Error: ${error.message}`));
      process.exit(1);
    }
  });

// 主交互流程
async function runInteractive(options) {
  console.log(chalk.bold.cyan('\n🦙 GGUF Model Runner\n'));

  // 1. 扫描 GGUF 文件 (扫描 models 目录)
  // 优先使用当前工作目录的 models，如果不存在则使用包安装目录的 models
  let modelsDir = path.join(process.cwd(), 'models');
  let ggufFiles = [];

  if (!options.model) {
    try {
      ggufFiles = scanGGUFFiles(modelsDir);
    } catch (error) {
      // 如果当前目录没有 models，尝试使用包安装目录的 models
      try {
        const packageDir = path.resolve(__dirname, '..');
        modelsDir = path.join(packageDir, 'models');
        ggufFiles = scanGGUFFiles(modelsDir);
      } catch (fallbackError) {
        // 如果包安装目录也没有 models，提示用户
        throw new Error('No "models" directory found or no GGUF files in models/. Please create a "models" directory and put your .gguf files there.');
      }
    }

    if (ggufFiles.length === 0) {
      throw new Error('No GGUF files found in models/ directory. Please ensure you have .gguf files in the models/ directory.');
    }
  }

  // 2. 交互式配置
  const questions = buildPromptQuestions(options, ggufFiles, modelsDir);
  const answers = await inquirer.prompt(questions);

  // 合并命令行参数和交互式输入
  // 注意：只有当用户通过命令行明确提供参数时才使用命令行值，否则使用交互式输入
  // 模型路径转换为绝对路径，确保在任何目录运行都能找到模型文件
  const modelFile = options.model || answers.model;
  const modelPath = options.model
    ? path.resolve(modelFile)  // 命令行指定的路径，转换为绝对路径
    : path.resolve(modelsDir, modelFile);  // 使用扫描得到的 modelsDir 构建绝对路径

  // 处理 mmproj 路径
  let mmprojPath = null;
  if (options.mmproj) {
    // 命令行指定的 mmproj，转换为绝对路径
    mmprojPath = path.resolve(options.mmproj);
  } else if (answers.mmproj && answers.mmproj !== 'None') {
    // 交互式选择的 mmproj，从 mmprojs 目录构建路径
    const mmprojsDir = path.join(path.dirname(modelsDir), 'mmprojs');
    mmprojPath = path.resolve(mmprojsDir, answers.mmproj);
  }

  const config = {
    model: modelPath,  // 使用绝对路径
    mmproj: mmprojPath,  // 多模态投影文件路径 (可选)
    ctxSize: answers.ctxSize,  // 交互式输入优先
    host: answers.host,  // 交互式输入优先
    port: answers.port,  // 交互式输入优先
    extraArgs: answers.extraArgs,
    llamaCommand: answers.llamaCommand
  };

  // 3. 显示完整命令并确认
  const command = buildLlamaCommand(config);

  console.log(chalk.dim('\n📝 Command to execute:'));
  console.log(chalk.green(command));

  const { confirmRun } = await inquirer.prompt([
    {
      type: 'confirm',
      name: 'confirmRun',
      message: 'Run this command?',
      default: true
    }
  ]);

  if (!confirmRun) {
    console.log(chalk.yellow('Cancelled.'));
    return;
  }

  // 4. 执行命令
  console.log(chalk.dim('\n🚀 Starting llama...\n'));
  await runLlama(config);
}

program.parse();
