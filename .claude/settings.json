{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(wmic cpu:*)",
      "Bash(systeminfo)",
      "Bash(wmic OS get FreePhysicalMemory,TotalVisibleMemorySize /format:list)",
      "Bash(powershell -Command \"Get-CimInstance Win32_OperatingSystem | Select-Object TotalPhysicalMemory\")",
      "Bash(nvidia-smi --query-gpu=name,memory.total,driver_version --format=csv,noheader)",
      "Bash(powershell -Command \"Get-CimInstance Win32_Processor | Select-Object Name,NumberOfCores,NumberOfLogicalProcessors | Format-List\")",
      "Bash(wmic memorychip:*)",
      "Bash(cmd /c \"wmic memorychip get capacity\")"
    ]
  }
}
